include LICENSE
include README.md
include THIRD_PARTY_NOTICES.md
include pyproject.toml
include .gitattributes
include .gitignore

recursive-include .github *.yml
recursive-include configs *.json
recursive-include docs *.md *.svg
recursive-include evals *.json
recursive-include examples *.json
recursive-include results/published *.json *.md
recursive-include tests *.json *.jsonl *.md *.py SHA256SUMS

global-exclude __pycache__
global-exclude *.py[cod]
