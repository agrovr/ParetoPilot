* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
*.py text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.html text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.toml text eol=lf
*.yml text eol=lf
LICENSE text eol=lf
results/published/**/*.log text eol=lf -whitespace
results/published/**/*.txt text eol=lf -whitespace
results/published/**/*.sha256 text eol=lf
results/published/**/SHA256SUMS text eol=lf
results/published/**/SOURCE-SHA256SUMS text eol=lf

# The paired-study fixture is checksummed; preserve LF bytes on every platform.
tests/fixtures/paired-study/** text eol=lf
